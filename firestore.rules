rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Every user can only ever read/write their own document
    // (users/{uid}) and anything nested under it (e.g. game_data/apiary).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
